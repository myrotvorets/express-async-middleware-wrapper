{
  "name": "@myrotvorets/express-async-middleware-wrapper",
  "version": "2.2.3",
  "description": "Wrapper for Express.js async middleware to handle rejected promises and synchronous exceptions",
  "main": "dist/lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint -f gha .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "test": "node --require=ts-node/register/transpile-only test-runner.ts",
    "test:coverage": "c8 npm test"
  },
  "files": [
    "dist/lib/index.d.ts",
    "dist/lib/index.js",
    "dist/lib/index.js.map"
  ],
  "typings": "dist/lib/index.d.ts",
  "keywords": [
    "express",
    "async",
    "await",
    "middleware",
    "handle rejected promises",
    "express middleware"
  ],
  "author": "Myrotvorets <support@myrotvorets.center> (https://myrotvorets.center/)",
  "license": "MIT",
  "devDependencies": {
    "@myrotvorets/eslint-config-myrotvorets-ts": "^3.1.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "eslint-formatter-gha": "^2.0.1",
    "express": "^5.2.1",
    "node-reporter-gha": "^2.0.8",
    "node-reporter-sonarqube": "^1.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myrotvorets/express-async-middleware-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/myrotvorets/express-async-middleware-wrapper/issues"
  },
  "homepage": "https://github.com/myrotvorets/express-async-middleware-wrapper#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
